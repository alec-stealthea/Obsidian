<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="Willow Inventory Provincial Vaccine - Application Context" id="model-willow-inv" version="5.0.0">
  <purpose>Application Context Model for Willow Inventory (Epic) within the Provincial Vaccine Depot. Author: Alec - Stealth EA. Last edited: 2026-06-12.</purpose>
  <folder name="Strategy" id="folder-strategy" type="strategy"/>
  <folder name="Business" id="folder-business" type="business">
    <element xsi:type="archimate:BusinessRole" name="Depot / Inventory Pharmacist" id="role_pharm" documentation="**Primary operator** of Willow Inventory at the Provincial Vaccine Depot. Works the full inventory lifecycle day-to-day — receiving shipments, put-away, stock control and cycle counts, allocation to sites, and recording wastage and adjustments. Modelled as a *role* rather than a named individual so the view stays stable as staff change."/>
    <element xsi:type="archimate:BusinessRole" name="Inventory / Supply Analyst" id="role_analyst" documentation="**Analytic consumer** of inventory data. Uses Willow&#8217;s operational reports for day-to-day questions and the *Snowflake Analytics Repository* for self-serve analysis, demand forecasting and seasonal planning. Does not transact in Willow; depends on the ETL pipeline being current."/>
    <element xsi:type="archimate:Stakeholder" name="Community &amp; Hospital Pharmacies" id="stk_pharmacies" documentation="External pharmacy organizations — community and hospital — that hold and dispense vaccine. They operate interface-capable **Pharmacy Information Systems** whose stock and dispense activity reaches Willow through IBM ACE. Directly affected by any change to the PIS interface."/>
    <element xsi:type="archimate:Stakeholder" name="Vaccine Distributor / Supply Chain" id="stk_distributor" documentation="Distribution / supply-chain partner that fulfils depot purchase orders for products ordered **through distribution**. Receives X12 850 POs (transformed by ACE) and returns 855 acknowledgements, 856 ASNs and 810 invoices. Its EDI trading-partner configuration is distinct from the manufacturers&#8217;."/>
    <element xsi:type="archimate:Stakeholder" name="Vaccine Manufacturer" id="stk_manufacturer" documentation="Manufacturer from which the depot orders **direct** rather than through distribution. Receives purchase orders via ACE in its required EDI/API format and returns 855/856/810 documents. Distinguished from the distributor because products, contracts and trading-partner setup differ."/>
    <element xsi:type="archimate:Stakeholder" name="Physician &amp; Pharmacy Sites (no interface capability)" id="stk_sites" documentation="Sites whose information systems cannot support a true interface. They participate through the custom **Pharmacy &amp; Physician Inventory Portal**, submitting manual counts and orders and viewing depot stock. The portal is the governed alternative to swivel-chair transcription for this group."/>
  </folder>
  <folder name="Application" id="folder-application" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Willow Inventory (Epic)" id="app_willow" documentation="**(G)** The governed application of record for Provincial Vaccine Depot inventory — the Application Catalogue entry this model contextualizes. Composed of six functions (procurement through reporting) over the *Vaccine Inventory Record*. Always the **buyer** in this model: per the Epic X12 interface specification it natively generates outbound 850 purchase orders and consumes inbound 855, 856, 810 and 832 documents."/>
    <element xsi:type="archimate:ApplicationFunction" name="Procurement &amp; Purchase Ordering" id="fn_procure" documentation="Generates purchase orders (**X12 850**) to manufacturers and distributors, driven by par levels and reorder points, and processes inbound **855** PO acknowledgements, **856** ASNs, **810** invoices and **832** price/catalogue updates. The PO originates here — in Willow, not in ACE."/>
    <element xsi:type="archimate:ApplicationFunction" name="Receiving &amp; Put-Away" id="fn_receive" documentation="Receives inbound vaccine shipments against expected POs and ASNs and puts stock away to locations, capturing **lot and expiry at the door**. The point where physical product becomes inventory record."/>
    <element xsi:type="archimate:ApplicationFunction" name="Stock Management &amp; Cycle Counts" id="fn_stock" documentation="Maintains on-hand balances, **lot/expiry tracking** and **cold-chain status**, and supports cycle counting to keep the *Vaccine Inventory Record* true to what is actually on the shelf."/>
    <element xsi:type="archimate:ApplicationFunction" name="Allocation &amp; Distribution" id="fn_alloc" documentation="Allocates available vaccine and records distribution from the depot out to depots, clinics and sites — the **outbound half** of the inventory lifecycle."/>
    <element xsi:type="archimate:ApplicationFunction" name="Wastage &amp; Adjustments" id="fn_waste" documentation="Records wastage (expiry, cold-chain excursions, breakage), returns and inventory adjustments — preserving an **auditable account** of every dose that does not reach an arm."/>
    <element xsi:type="archimate:ApplicationFunction" name="Inventory Reporting &amp; Dashboards" id="fn_report" documentation="Operational reporting and dashboards over **live inventory data** within Willow. Serves day-to-day operational questions; deeper analytics and forecasting belong downstream in Snowflake."/>
    <element xsi:type="archimate:DataObject" name="Vaccine Inventory Record" id="do_inv" documentation="The Willow inventory data store: on-hand quantities, lot, expiry, location and transaction history. **Single source of truth** for depot inventory — read and written by the application functions and extracted to Snowflake for analytics."/>
    <element xsi:type="archimate:ApplicationComponent" name="Pharmacy &amp; Physician Inventory Portal" id="app_portal" documentation="**Custom-developed** complement to Epic. Gives sites without interface-capable systems a governed entry point for manual counts and orders, returns depot stock visibility, and surfaces Snowflake reporting datasets. The deliberate replacement for uncontrolled screen-to-screen transcription."/>
    <element xsi:type="archimate:ApplicationComponent" name="IBM App Connect Enterprise (ACE)" id="app_ace" documentation="The **integration engine** mediating all external interfaces. All translation and transformation logic (HL7, EDI, API) lives here, so external format changes are absorbed in one place rather than in Epic. Routes Willow&#8217;s 850 POs outbound; routes supplier 855/856/810 documents and PIS stock/dispense messages inbound."/>
    <element xsi:type="archimate:ApplicationComponent" name="Snowflake Analytics Repository" id="app_snow" documentation="Cloud analytics repository fed by **ETL (Clarity/Caboodle)** from Willow. Separates analytic workloads from the operational Epic system; serves the curated *Inventory Analytics Dataset* to the portal and self-serve analytics to the Inventory / Supply Analyst."/>
    <element xsi:type="archimate:DataObject" name="Inventory Analytics Dataset" id="do_analytics" documentation="Curated analytic **data product** served from Snowflake — inventory positions, consumption history and forecasts. Consumed by the portal&#8217;s reporting views and by analyst self-serve tools."/>
    <element xsi:type="archimate:ApplicationComponent" name="Pharmacy Information System (PIS)" id="app_pis" documentation="External, interface-capable pharmacy information system operated by community and hospital pharmacies. Sends **stock/dispense messages (HL7/API)** into ACE, which transforms and delivers inventory updates and receipts to Willow. Represents a *class* of systems rather than a single product."/>
    <element xsi:type="archimate:ApplicationComponent" name="Vaccine Distribution System" id="app_dist" documentation="The distributor&#8217;s order-management / warehouse system. Receives depot purchase orders (**EDI/API via ACE**) and returns 855 acknowledgements, 856 ASNs and 810 invoices through the same channel."/>
    <element xsi:type="archimate:ApplicationComponent" name="Manufacturer Order Management System" id="app_mfr" documentation="The manufacturer&#8217;s order-management system for **direct orders**. Receives POs in the manufacturer&#8217;s required EDI/API format via ACE and returns 855/856/810 documents. Trading-partner configuration differs from the distributor&#8217;s."/>
  </folder>
  <folder name="Technology &amp; Physical" id="folder-technology" type="technology"/>
